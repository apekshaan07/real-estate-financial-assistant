# Copy values into Streamlit Cloud → App Settings → Secrets
# Do NOT commit real keys to GitHub.

GOOGLE_CLOUD_PROJECT = "real-estate-ai-apeksha"
GOOGLE_CLOUD_LOCATION = "us-central1"
GOOGLE_GENAI_USE_VERTEXAI = "true"
USE_VERTEX_ADK = "true"
VERTEX_MODEL = "gemini-2.5-flash"

AWS_REGION = "us-east-1"
AWS_ACCESS_KEY_ID = "your-aws-access-key"
AWS_SECRET_ACCESS_KEY = "your-aws-secret-key"
SAGEMAKER_REGRESSION_ENDPOINT = "housing-regression-endpoint"
SAGEMAKER_CLASSIFICATION_ENDPOINT = "bank-classification-endpoint"

USE_BEDROCK = "true"
BEDROCK_MODEL_ID = "amazon.nova-lite-v1:0"

USE_SEC_EDGAR = "true"
SEC_COMPANY_CIK = "0001045609"
SEC_USER_AGENT = "RealEstateFinancialAssistant/1.0 (your-email@example.com)"

USE_AZURE_OPENAI = "false"

# Leave DATABASE_URL unset on Streamlit Cloud (SQLite auto-seeds from sql/seed_data.sql)
