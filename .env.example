# Database
# Leave unset for SQLite fallback during local demo.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real_estate_finance

# GCP Vertex AI ADK chatbot
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
USE_VERTEX_ADK=true
VERTEX_MODEL=gemini-2.5-flash

# AWS SageMaker
AWS_REGION=us-east-1
SAGEMAKER_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_SAGEMAKER_ROLE
SAGEMAKER_REGRESSION_ENDPOINT=housing-regression-endpoint
SAGEMAKER_CLASSIFICATION_ENDPOINT=bank-classification-endpoint

# AWS Bedrock summarization
USE_BEDROCK=false
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Azure OpenAI summarization
USE_AZURE_OPENAI=false
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# SEC EDGAR (Prologis CIK)
USE_SEC_EDGAR=true
SEC_COMPANY_CIK=0001045609
SEC_USER_AGENT=RealEstateFinancialAssistant/1.0 (your-email@example.com)
